<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark">논</span>
        <span>
          <strong>논준모연구소</strong>
          <small>방학 오프라인 특강 신청</small>
        </span>
      </a>
      <nav class="top-nav">
        <a href="/">특강 목록</a>
        <% if (isAdmin) { %>
          <a href="/admin">관리자</a>
          <form method="post" action="/admin/logout">
            <button type="submit" class="link-button">로그아웃</button>
          </form>
        <% } else { %>
          <a href="/admin/login">관리자 로그인</a>
        <% } %>
      </nav>
    </header>
    <main class="page">
      <%- body %>
    </main>
  </body>
</html>
